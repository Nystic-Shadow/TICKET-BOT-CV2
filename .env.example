# Required. Create a fresh token in the Discord Developer Portal.
DISCORD_TOKEN=

# Bot behavior
BOT_PREFIX=!
BOT_STATUS=!help | /help
BOT_STATUS_TYPE=WATCHING
SUPPORT_SERVER_URL=
STREAM_URL=

# Attribution and ticket defaults shown by the bot
DEFAULT_PANEL_FOOTER=Developed by Nystic Shadow
TICKET_BANNER_URL=
TICKET_RULES_TEXT=Describe the issue clearly, include relevant evidence, and avoid duplicate tickets.

# Runtime paths and logging
DATABASE_PATH=bot.db
TRIGGERS_DATABASE_PATH=triggers.db
LOG_PATH=bot.log
LOG_LEVEL=INFO

# Purple application-emoji sync (no guild/server emoji uploads)
AUTO_SYNC_APPLICATION_EMOJIS=true
EMOJI_DIRECTORY=emojis
# Used only by the optional manual sync script; startup discovers this automatically.
DISCORD_APPLICATION_ID=
